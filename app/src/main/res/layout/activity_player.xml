<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:padding="20dp">

    <!-- Top Custom Header -->
    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_media_previous"
            android:contentDescription="Back"
            app:tint="@color/text_premium_cream"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOW PLAYING"
            android:textColor="@color/text_muted_grey"
            android:textSize="13sp"
            android:letterSpacing="0.2"
            android:fontFamily="sans-serif-black"
            android:layout_centerInParent="true"/>
    </RelativeLayout>

    <!-- Center Premium Blurred Album Card Cover -->
    <LinearLayout
        android:id="@+id/layoutAlbumArt"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@id/layoutHeader"
        android:background="@drawable/bg_glass_card"
        android:gravity="center"
        android:layout_marginHorizontal="8dp"
        android:layout_marginBottom="24dp"
        android:elevation="4dp">

        <ImageView
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/text_premium_cream"
            android:alpha="0.8"
            android:contentDescription="Music Cover Icon"/>
    </LinearLayout>

    <!-- Song Title Info -->
    <TextView
        android:id="@+id/tvPlayerSongTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutAlbumArt"
        android:text="Song Title"
        android:textColor="@color/text_premium_cream"
        android:textSize="22sp"
        android:fontFamily="sans-serif-light"
        android:gravity="center"
        android:layout_marginBottom="24dp"
        android:paddingHorizontal="16dp"
        android:ellipsize="end"
        android:maxLines="1"/>

    <!-- Bottom Controls Subtle Glass Layout (Padding Adjusted to avoid cutting) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvPlayerSongTitle"
        android:background="@drawable/bg_glass_card"
        android:orientation="vertical"
        android:paddingVertical="16dp"
        android:paddingHorizontal="20dp">

        <!-- Custom Seekbar -->
        <SeekBar
            android:id="@+id/playerSeekBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="0"
            android:splitTrack="false"
            android:progressTint="@color/solar_accent"
            android:thumbTint="@color/text_premium_cream"/>

        <!-- Premium Clean Timestamps -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:paddingHorizontal="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_muted_grey"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_alignParentStart="true"/>

            <TextView
                android:id="@+id/tvTotalDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="00:00"
                android:textColor="@color/text_muted_grey"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"
                android:layout_alignParentEnd="true"/>
        </RelativeLayout>

        <!-- Play/Pause Toggle Touch Icon -->
        <ImageView
            android:id="@+id/btnPlayPause"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_horizontal"
            android:src="@android:drawable/ic_media_play"
            app:tint="@color/solar_accent"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="Play Pause Toggle"/>
    </LinearLayout>

</RelativeLayout>